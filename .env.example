# =============================================
# DATABASE
# =============================================
DATABASE_URL="postgresql://user:password@localhost:5432/guyafibre?schema=public"

# =============================================
# AUTHENTICATION
# =============================================
JWT_SECRET="generate-a-256-bit-secret-here"
JWT_REFRESH_SECRET="generate-another-256-bit-secret-here"

# =============================================
# FRONTEND URL (for CORS)
# =============================================
FRONTEND_URL="http://localhost:3000"

# =============================================
# EMAIL (Resend)
# =============================================
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@guyafibre.com"
EMAIL_FROM_NAME="GUYA FIBRE"
ADMIN_EMAIL="contact@guyafibre.com"

# =============================================
# UPLOADS
# =============================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# =============================================
# NODE ENVIRONMENT
# =============================================
NODE_ENV="development"
PORT=4000
